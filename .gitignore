# Local runtime config (vault path, port) — machine-specific, not shared
config.json

# Secrets — credentials/tokens live in ~/.config/manifest/, never in the repo
client_secret_*.json
google_credentials.json
google_token.json

# Rebuildable index / cache (never source of truth)
*.db
*.db-wal
*.db-shm

# Compiled binaries (single-binary builds in-tree)
/app/app
/app/manifest

# Local-only working material — repo is public, only /app is shared
/context/
/plans/
/.claude/

# OS cruft
.DS_Store
